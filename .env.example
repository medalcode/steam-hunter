# ──────────────────────────────────────────────
# Steam Hunter — Environment Variables
# ──────────────────────────────────────────────

# ── ASF (ArchiSteamFarm) ──────────────────────
ASF_IPC_PASSWORD=
ASF_DEFAULT_BOT=principal
ASF_AUTO_REDEEM=true
ASF_USER=medalcode
ASF_HEADLESS=true
ASF_IPC_URL=http://asf:1242

# ── Steam Hunter Backend ──────────────────────
STEAM_HUNTER_API_KEY=
STEAM_HUNTER_DB_DIR=/app/data
LOG_LEVEL=INFO

# ── Xbox Scraper ──────────────────────────────
XBOX_CATALOG_PAGES=15
XBOX_COOKIES=
XBOX_COOKIES_FILE=

# ── Free Games Claimer ────────────────────────
CLAIM_EPIC=1
CLAIM_PRIME=1
CLAIM_GOG=1
NOTIFY=1
SHOW_BROWSER=0
